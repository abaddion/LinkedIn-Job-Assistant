{
  "manifest_version": 3,
  "name": "LinkedIn Job Assistant",
  "version": "1.0.1",
  "description": "AI-powered LinkedIn assistant helping job seekers connect with hiring managers and recruiters professionally",
  "author": "barush.jensik@gmail.com",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://api.openai.com/*"
  ],
  "content_scripts": [{
    "matches": ["https://*.linkedin.com/*"],
    "css": ["content.css"],
    "js": ["content.js"]
  }],
  "web_accessible_resources": [{
    "resources": [
      "images/icon-48.png",
      "images/icon-side-48.png"
    ],
    "matches": ["https://*.linkedin.com/*"]
  }],
  "background": {
    "service_worker": "background.js"
  }
}